#!/command/with-contenv sh
# Session loop service — supervised by s6
# SESSION_NAME, WORKDIR, and SESSION_TYPE are injected via docker-compose environment
# Ensure scripts are executable (bind mounts can strip permissions)
chmod +x /relay/scripts/claude-session-loop.sh /relay/scripts/copilot-session-loop.sh /relay/scripts/message-watchdog.sh 2>/dev/null || true
export S6_SUPERVISED=1
if [ "${SESSION_TYPE}" = "copilot" ]; then
  exec /relay/scripts/copilot-session-loop.sh "${SESSION_NAME}" "${WORKDIR}"
else
  exec /relay/scripts/claude-session-loop.sh "${SESSION_NAME}" "${WORKDIR}"
fi
