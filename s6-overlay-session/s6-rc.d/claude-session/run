#!/command/with-contenv sh
# Claude session loop service — supervised by s6
# SESSION_NAME and WORKDIR are injected via docker-compose environment
# Ensure scripts are executable (bind mounts can strip permissions)
chmod +x /relay/scripts/claude-session-loop.sh /relay/scripts/mcp-server-wrapper.sh /relay/scripts/message-watchdog.sh 2>/dev/null || true
export S6_SUPERVISED=1
exec /relay/scripts/claude-session-loop.sh "${SESSION_NAME}" "${WORKDIR}"
