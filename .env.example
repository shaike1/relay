TELEGRAM_BOT_TOKEN=your_bot_token_here
OWNER_ID=your_telegram_user_id
GROUP_CHAT_ID=-1001234567890

# Optional: send critical alerts as direct DMs to this Telegram user ID
# Get your ID from @userinfobot. Must have started a chat with the bot first.
NOTIFY_USER_ID=123456789

# Optional: proactive check interval in minutes (0 = disabled)
# When set, Claude wakes up on this interval to check for anything worth reporting
PROACTIVE_INTERVAL=0

# Claude OAuth token (from ~/.claude.json or claude.ai)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Optional: remote host for additional session containers
REMOTE_HOST=root@your-secondary-server

# Optional: thread IDs for monitoring alerts (defaults shown)
DISK_MONITOR_THREAD_ID=213
SELF_MONITOR_THREAD_ID=183

# Optional: Cloudflare API token for DNS management
CLOUDFLARE_API_TOKEN=cfat_...
